{
    "workbench.colorTheme": "Dark Orange Default",
    "git.autofetch": true,
    "editor.fontFamily": "'CommitMono Nerd Font Mono', 'monospace'",
    "terminal.integrated.fontFamily": "'CommitMono Nerd Font Mono'",
    "debug.console.fontFamily": "'CommitMono Nerd Font Mono'",
    "markdown.preview.fontFamily": "'CommitMono Nerd Font Mono'",
    "workbench.enableExperiments": false,
    "workbench.editorAssociations": {
        "*.pdf": "default"
    },
    "workbench.sideBar.location": "right",
    "vim.normalModeKeyBindingsNonRecursive": [
        // LSP Config
        {
            "before": ["g", "R"],
            "commands": ["editor.action.referenceSearch.trigger"]
        },
        {
            "before": ["g", "d"],
            "commands": ["editor.action.showDefinition"]
        },
        {
            "before": ["g", "p", "d"],
            "commands": ["editor.action.peekDefinition"]
        },
        {
            "before": ["g", "D"],
            "commands": ["editor.action.goToDeclaration"]
        },
        {
            "before": ["g", "i"],
            "commands": ["editor.action.goToImplementation"]
        },
        {
            "before": ["g", "p", "i"],
            "commands": ["editor.action.peekImplementation"]
        },
        {
            "before": ["g", "t"],
            "commands": ["editor.action.goToTypeDefinition"]
        },
        {
            "before": ["g", "p", "t"],
            "commands": ["editor.action.peekTypeDefinition"]
        },
        {
            "before": ["g", "K"],
            "commands": ["editor.action.showHover"]
        },
        {
            "before": ["g", "r"],
            "commands": ["editor.action.rename"]
        },
        {
            "before": ["g", "h"],
            "commands": ["editor.action.showHover"]
        },
        {
            "before": ["g", "q"],
            "commands": ["editor.action.quickFix"]
        },
        // Plugin Config
        {
            "before": ["<Space>", "f", "f"],
            "commands": ["find-it-faster.findFiles"]
        },
        {
            "before": ["<Space>", "f", "w"],
            "commands": ["find-it-faster.findWithinFiles"]
        },
        {
            "before": ["<Space>", "j"],
            "commands": ["workbench.action.terminal.toggleTerminal"]
        },
        {
            "before": ["<Space>", "b"],
            "commands": ["workbench.action.toggleSidebarVisibility"]
        },
        {
            "before": ["<Space>", "g"],
            "commands": ["workbench.view.scm"]
        },
        {
            "before": ["g", "h"],
            "commands": ["editor.action.showHover"]
        },
    ],
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "remote.autoForwardPortsSource": "hybrid",
    "git.ignoreRebaseWarning": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "claudeCode.preferredLocation": "sidebar",
    "editor.aiStats.enabled": true,
    "buildFiller.enabled": false,
    "editor.formatOnSave": true
}
